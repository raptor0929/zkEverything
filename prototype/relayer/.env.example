# Port the relayer HTTP server listens on
PORT=3000

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Path to the relayer's funded Solana keypair JSON (id.json format)
# This wallet pays transaction fees and nullifier-record rent (~0.002 SOL per redeem)
RELAYER_KEYPAIR_PATH=~/.config/solana/id.json

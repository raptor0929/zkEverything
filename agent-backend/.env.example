# OpenAI API key for the agent LLM
OPENAI_API_KEY=sk-...

# BLS secret key hex for the mint (used in announce step)
MINT_SK=0x...

# JSON array of secret key bytes for the relayer wallet (transaction payer)
# Example: [12,34,56,...]
RELAYER_KEYPAIR=[...]

# Solana RPC endpoint (devnet)
RPC_URL=https://api.devnet.solana.com

# Express server port
PORT=4000

# Vercel frontend URL for CORS (e.g. https://your-app.vercel.app)
ALLOWED_ORIGIN=http://localhost:3000

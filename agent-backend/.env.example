# OpenAI API key for the agent LLM
OPENAI_API_KEY=sk-...

# BLS secret key for the mint (hex scalar, no 0x prefix needed).
# On devnet the MintState was initialized with:
#   mintSk = new mcl.Fr(); mintSk.setHashOf("ghost_vault_devnet_mint_key_v1")
# To export the hex value run: mintSk.getStr(16)
MINT_SK=<hex scalar from mintSk.getStr(16)>

# JSON array of secret key bytes for the relayer Solana wallet.
# Fee payer for deposit and redeem instructions.
# Must have enough devnet SOL: 0.01 SOL per payment + ~0.002 SOL fees.
# Example: solana-keygen new --outfile relayer.json && cat relayer.json
RELAYER_KEYPAIR=[12,34,56,...]

# JSON array of secret key bytes for the mint Solana wallet.
# Fee payer for the announce instruction only (~0.000005 SOL per tx).
# Keep topped up: solana airdrop 1 <pubkey> --url devnet
MINT_KEYPAIR=[12,34,56,...]

# Solana RPC endpoint (devnet)
RPC_URL=https://api.devnet.solana.com

# Express server port
PORT=4000

# Vercel frontend URL for CORS (e.g. https://your-app.vercel.app)
ALLOWED_ORIGIN=http://localhost:3000

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://xxxx.supabase.co

# Supabase JWT secret — found in: Dashboard > Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

# Supabase service role key — found in: Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# 32-byte hex key for AES-256-GCM encryption of agent keypairs at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_ENCRYPTION_KEY=<64-char hex string>
